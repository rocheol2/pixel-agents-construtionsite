# OpenRouter API key. Required from Step 6 (planner.ts) onward; Step 1 boots without it.
OPENROUTER_API_KEY=

# Optional: override OpenRouter base URL (OpenAI-compatible). Defaults to https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=

# Optional: override ~/.pixel-agents for isolated local testing (defaults to the real home dir).
PIXEL_AGENTS_HOME=

# Optional: override ~/.claude for isolated local testing (defaults to the real home dir).
CLAUDE_HOME=

# Optional: the workspace directory Pixel Agents (npx pixel-agents) is watching.
# MUST match the directory you ran `npx pixel-agents` from, or the session
# lands in the wrong ~/.claude/projects/<hash>/ folder and won't be picked up.
# Defaults to the directory the driver itself is run from.
PIXEL_AGENTS_WORKSPACE=

# Multi-agent roster (Step 10). Define AGENT_1_*, AGENT_2_*, ... — numbering must
# start at 1 and be contiguous; config.ts stops at the first missing _NAME.
# If no AGENT_1_NAME is set at all, a single default agent ("김대리") is used.
# AGENT_<n>_API_KEY is optional per-agent; falls back to OPENROUTER_API_KEY above.
# Use literal "\n" inside AGENT_<n>_SYSTEM_PROMPT for multi-line prompts.

AGENT_1_NAME=김대리
AGENT_1_MODEL=openai/gpt-4o-mini
AGENT_1_SYSTEM_PROMPT=당신은 성실한 사무직 직원입니다.
AGENT_1_API_KEY=

AGENT_2_NAME=박주임
AGENT_2_MODEL=anthropic/claude-3.5-haiku
AGENT_2_SYSTEM_PROMPT=당신은 꼼꼼하고 신중한 사무직 직원입니다.
AGENT_2_API_KEY=
